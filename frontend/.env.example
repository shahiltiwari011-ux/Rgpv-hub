# ================================================
# RGPV Study Hub — Environment Variables
# ================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
#
# For deployment (Vercel/Netlify), add these in the
# platform's Environment Variables dashboard.
# ================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_URL=https://your-backend-proxy.railway.app
VITE_SITE_URL=https://rgpv-hub.vercel.app/
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_SLOT_BANNER=1234567890
VITE_ADSENSE_SLOT_HORIZONTAL=1234567890
VITE_ADSENSE_SLOT_SQUARE=1234567890
VITE_ADSENSE_SLOT_SIDEBAR=1234567890
